{
  "engine": "auto",
  "codex_model": "gpt-5.1-codex-max",
  "claude_model": "sonnet",
  "gemini_model": "auto",
  "session_reuse_seconds": 7200,
  "finalize": true,
  "prompt_mode": "paths",
  "auto_compact": true,
  "auto_compact_ai": false,
  "auto_cleanup": true,
  "decision_keep_days": 30,
  "transcript_keep_days": 30,
  "fallback_engine": "",
  "fallback_model": "",
  "fallback_on_quota": false,
  "token_budget_est": 2500,
  "warn_budget_pct": 80,
  "digest_max_lines": 60,
  "context_max_lines": 20,
  "decisions_max_chars": 5000,
  "todo_max_chars": 1200,
  "skills": {
    "enabled": true,
    "auto_select": true,
    "max_active": 2,
    "intent_map": {
      "impl": ["triage", "impl"],
      "review": ["triage", "review-critical"],
      "tests": ["triage", "test-strategy"],
      "release": ["triage", "release-safety"],
      "refactor": ["triage", "refactor-safe"],
      "debug": ["triage", "debug-root-cause"],
      "finalize": ["memory-hygiene"],
      "compact": ["token-budget-guard"]
    }
  }
}
